[Unit]
Description=Ngoc Rong Game Server
After=network.target mariadb.service mysqld.service
Wants=network-online.target

[Service]
Type=simple
User=ngocrong
Group=ngocrong
WorkingDirectory=/opt/ngocrong
Environment=JAVA_HOME=/usr/lib/jvm/java-17-openjdk
Environment=XMS=1G
Environment=XMX=4G
ExecStart=/opt/ngocrong/run.sh
Restart=always
RestartSec=10
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
